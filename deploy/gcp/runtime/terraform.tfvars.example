state_bucket                 = "attune-development-example-attune-tfstate"
foundation_state_prefix      = "foundation"
audit_writer_image           = "northamerica-northeast1-docker.pkg.dev/PROJECT/REPOSITORY/attune-audit-writer@sha256:REPLACE"
dispatch_broker_image        = "northamerica-northeast1-docker.pkg.dev/PROJECT/REPOSITORY/attune-dispatch-broker@sha256:REPLACE"
# Change only after the foundation jobs queue has its reviewed fixed override.
enable_dispatch_broker       = false
secret_broker_image          = "northamerica-northeast1-docker.pkg.dev/PROJECT/REPOSITORY/attune-secret-broker@sha256:REPLACE"
oauth_exchange_image         = "northamerica-northeast1-docker.pkg.dev/PROJECT/REPOSITORY/attune-oauth-exchange@sha256:REPLACE"
oauth_min_instance_count = 0
worker_image                 = "northamerica-northeast1-docker.pkg.dev/PROJECT/REPOSITORY/attune-worker@sha256:REPLACE"

# Keep false until the credential-free egress probe, a verified paging channel,
# and the dedicated non-production Google identity are ready.
enable_google_gmail_profile = false
enable_google_workspace_verification = false

# Required before customer credentials. Empty still creates a visible incident
# in Cloud Monitoring but sends no page.
alert_notification_channels = [
  # "projects/PROJECT/notificationChannels/NUMERIC_ID",
]

labels = {
  owner       = "platform"
  cost_center = "attune"
}
