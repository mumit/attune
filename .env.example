# Copy to .env and fill in — or let `aidedecamp init` write this for you.
# NEVER commit the filled-in .env. In hardened deployments these come from a
# secrets store (GCP Secret Manager — see docs/deployment.md), not a file.
#
# Poll mode (the default) needs only the first few sections. Everything
# under "PUSH MODE" is for the hardened Pub/Sub deployment.

# --- Fuel iX (required) ---
# Long-lived bearer token, rotated manually. On 401 the app fails loudly
# asking for rotation rather than retrying.
FUELIX_TOKEN=

# --- Deployment identity ---
# personal | telus
ADC_DEPLOYMENT=personal
# direct_oauth | mcp  (how Workspace is reached; direct_oauth works with
# plain OAuth credentials today)
ADC_CONNECTOR_MODE=direct_oauth
# The single identity this deployment acts as: memory/audit user_id and the
# Gmail API alias. Set your real address to enable the brief's "waiting on"
# section (quiet-thread detection matches against it); "me" also works.
ADC_USER_ID=me
# One directory for ALL mutable state (audit log, checkpoints, watch/poll
# baselines, pending approvals, conversation windows). Individual
# ADC_*_PATH/ADC_DB_PATH vars still override per file if you need to split.
ADC_DATA_DIR=~/.aidedecamp

# --- Google credentials ---
GOOGLE_PROJECT_ID=
# Path to a credentials JSON file: OAuth user credentials (from `aidedecamp
# init`'s consent flow — required for personal/consumer Gmail) or a service
# account (TELUS-style, with domain-wide delegation). Leave unset for
# google.auth.default() (ADC). See docs/deployment.md §4.
ADC_GOOGLE_CREDENTIALS_FILE=

# --- Ingestion ---
# poll (default: timer-driven, outbound-only, zero Pub/Sub) | push (Pub/Sub
# pull subscriptions fed by watches + the republisher — see PUSH MODE below).
ADC_INGESTION_MODE=poll
# Poll cadence in seconds (floored at 30).
ADC_POLL_SECONDS=120

# --- Cadence / locale ---
# IANA timezone for "today", brief times, and rendered event times.
ADC_TIMEZONE=UTC
# Local wall-clock HH:MM in ADC_TIMEZONE.
ADC_BRIEF_TIME=07:30
ADC_CONSOLIDATE_TIME=02:00
# Hours an approval card sits unanswered before it's captured as IGNORED.
ADC_APPROVAL_IGNORE_HOURS=48
# Conversational context window: turns kept / minutes before they expire.
ADC_CONVERSE_WINDOW_TURNS=10
ADC_CONVERSE_TTL_MINUTES=120

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
ADC_LOG_LEVEL=INFO
# 1 = one JSON object per line (journald / Cloud Logging); unset = plain.
ADC_LOG_JSON=

# --- Memory substrate (Qdrant via deploy/compose.yml; Mem0 runs in-process) ---
ADC_MEM0_URL=http://localhost:8000
# Set when the assistant runs in a container and Qdrant isn't localhost
# (deploy/compose.yml sets this to the qdrant service name).
ADC_QDRANT_HOST=
ADC_QDRANT_PORT=6333

# --- Slack (Socket Mode — approvals work fully in poll mode) ---
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
# Channel id for proactive posts (briefs, approval cards).
# Prefer an owner-only DM id (D...). C/G channel ids require the visibility
# acknowledgement below after verifying membership.
ADC_SLACK_CHANNEL=
# WHO may command the assistant (comma-separated Slack user IDs, e.g. U0123).
# Empty = deny everyone: Slack authenticates its workspace, not the human.
ADC_SLACK_ALLOWED_USERS=

# --- Google Chat ---
# Space name ("spaces/AAAA...") for proactive posts. Note: Chat approval
# *buttons* need the republisher's interaction subscription (below) even in
# poll mode — Google POSTs card clicks; there is nothing to poll.
ADC_CHAT_SPACE=
# WHO may command the assistant (comma-separated users/... resource names).
# Empty = deny everyone — anyone else in the space is politely refused.
ADC_CHAT_ALLOWED_USERS=
# Google Chat space names do not encode visibility. Set this only after
# verifying every configured proactive destination is owner-only, or after
# deliberately accepting that its members can read briefs and draft cards.
ADC_ACK_DESTINATION_VISIBILITY=

# =============================================================================
# PUSH MODE — everything below only matters with ADC_INGESTION_MODE=push
# (plus the Chat-interaction pair, which Chat approval buttons need in either
# mode). See docs/deployment.md.
# =============================================================================

# --- Gmail ingestion (Pub/Sub) ---
ADC_GMAIL_PUBSUB_TOPIC=
ADC_GMAIL_PUBSUB_SUBSCRIPTION=

# --- Chat ingestion (Workspace Events API, Pub/Sub) ---
ADC_CHAT_PUBSUB_TOPIC=
ADC_CHAT_PUBSUB_SUBSCRIPTION=

# --- Chat card-click interactions (approve/reject/edit-submit; the edit
# dialog's open click is answered synchronously by the republisher). The
# republisher's /chat-interaction route publishes here after verifying the
# request is genuinely from Google Chat; see rule 5 and docs/deployment.md. ---
ADC_CHAT_INTERACTION_PUBSUB_TOPIC=
ADC_CHAT_INTERACTION_PUBSUB_SUBSCRIPTION=

# --- Calendar ingestion (the other source needing a real webhook — the
# address is the external republisher's HTTPS endpoint, never anything this
# process listens on) ---
ADC_CALENDAR_PUBSUB_TOPIC=
ADC_CALENDAR_PUBSUB_SUBSCRIPTION=
ADC_CALENDAR_WEBHOOK_ADDRESS=
ADC_CALENDAR_ID=primary
