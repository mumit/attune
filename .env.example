# Copy to .env, or run `attune init`. Never commit the populated file.

# OpenAI-compatible Chat Completions API. The OpenAI SDK sends the API key as
# an Authorization: Bearer credential, including with a custom base URL.
ATTUNE_LLM_BASE_URL=https://api.openai.com/v1
ATTUNE_LLM_API_KEY=
ATTUNE_MODEL_DEFAULT=
# Optional task-specific overrides (otherwise MODEL_DEFAULT is used).
# ATTUNE_MODEL_CLASSIFY=
# ATTUNE_MODEL_DRAFT=
# ATTUNE_MODEL_REASON=
# ATTUNE_MODEL_CONSOLIDATE=
# ATTUNE_MODEL_CONVERSE=
# ATTUNE_MODEL_MEMORY_EXTRACT=
ATTUNE_EMBEDDING_BASE_URL=https://api.openai.com/v1
ATTUNE_EMBEDDING_API_KEY=
ATTUNE_EMBEDDING_MODEL=
# ATTUNE_EMBEDDING_DIMENSIONS=1536

# One Attune instance acts for one principal. Hosting is not encoded here.
ATTUNE_USER_ID=owner@example.com
ATTUNE_INTERNAL_DOMAINS=example.com
ATTUNE_DATA_DIR=~/.attune

# Workspace access: google_oauth (default) or mcp. MCP currently uses polling.
ATTUNE_WORKSPACE_BACKEND=google_oauth
ATTUNE_INGESTION_MODE=poll
ATTUNE_POLL_SECONDS=120

# Direct Google OAuth backend.
GOOGLE_PROJECT_ID=
ATTUNE_GOOGLE_CREDENTIALS_FILE=

# MCP backend (Streamable HTTP). Use one shared URL or both service URLs.
# ATTUNE_MCP_URL=
# ATTUNE_MCP_GMAIL_URL=
# ATTUNE_MCP_CALENDAR_URL=
# ATTUNE_MCP_TOKEN=

# Optional Slack destination and Socket Mode interaction surface.
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
ATTUNE_SLACK_CHANNEL=
ATTUNE_SLACK_ALLOWED_USERS=

# Optional Google Chat app. The service account authors proactive messages.
ATTUNE_CHAT_CREDENTIALS_FILE=
ATTUNE_CHAT_SPACE=
ATTUNE_CHAT_ALLOWED_USERS=

# Explicit delivery and interaction routing. Values are comma-separated
# `slack` and/or `google_chat`; approvals intentionally use one channel.
# `attune doctor` fails if a selected route lacks its required credential,
# destination, allowlist, or Chat interaction subscription.
ATTUNE_BRIEF_CHANNELS=
ATTUNE_APPROVAL_CHANNEL=
ATTUNE_NOTIFICATION_CHANNELS=
ATTUNE_INTERACTION_CHANNELS=
# Required for a non-DM Slack destination or any Chat space after visibility
# has been reviewed.
ATTUNE_ACK_DESTINATION_VISIBILITY=0

# Locale, cadence, and supervision.
ATTUNE_TIMEZONE=UTC
ATTUNE_BRIEF_TIME=07:30
ATTUNE_CONSOLIDATE_TIME=02:00
ATTUNE_NUDGE_TIME=14:00
ATTUNE_NUDGE_MIN_AGE_DAYS=4
ATTUNE_NUDGE_COOLDOWN_DAYS=7
ATTUNE_APPROVAL_IGNORE_HOURS=48
ATTUNE_CONVERSE_WINDOW_TURNS=10
ATTUNE_CONVERSE_TTL_MINUTES=120
ATTUNE_LOG_LEVEL=INFO
ATTUNE_LOG_JSON=
ATTUNE_QDRANT_HOST=
ATTUNE_QDRANT_PORT=6333

# Advanced Google Pub/Sub transport. Set INGESTION_MODE=google_pubsub.
ATTUNE_GMAIL_PUBSUB_TOPIC=
ATTUNE_GMAIL_PUBSUB_SUBSCRIPTION=
ATTUNE_CHAT_PUBSUB_TOPIC=
ATTUNE_CHAT_PUBSUB_SUBSCRIPTION=
# Chat app MESSAGE and CARD_CLICKED events share this verified handoff.
ATTUNE_CHAT_INTERACTION_PUBSUB_TOPIC=
ATTUNE_CHAT_INTERACTION_PUBSUB_SUBSCRIPTION=
ATTUNE_CALENDAR_PUBSUB_TOPIC=
ATTUNE_CALENDAR_PUBSUB_SUBSCRIPTION=
ATTUNE_CALENDAR_WEBHOOK_ADDRESS=
ATTUNE_CALENDAR_ID=primary
